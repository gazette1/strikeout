# Optional: OpenWeatherMap backup (Meteostat is primary, no key needed)
OPENWEATHER_API_KEY=your_key_here

# Discord alerts for daily strikeout projections (tools/daily_picks.py)
# Create one in Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# Data paths (override defaults in config/settings.py)
# DATA_DIR=/path/to/data
# MODEL_DIR=/path/to/models
