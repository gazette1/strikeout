# Secrets — NEVER commit (webhook lives here locally; in cloud it's a repo secret)
.env

# Virtualenv
.venv/

# Python
__pycache__/
*.pyc

# Large data caches (rebuilt / cached in CI, not committed)
data/raw/
data/features/
data/staging/
tools/out/

# data/predictions/ IS tracked — it's the persistent picks + results record
# (committed back by the cloud workflow each run so the rolling record survives)

# Personal betting log
*.xlsx

# Keep the trained model (small) — force-tracked despite data/ rules above
!data/models/
!data/models/production/
!data/models/production/*.txt
!data/models/production/*.json
